# Caddy plugin environment variables.
#
# Export these in the same shell that launches Claude Code, OR add them
# to your shell profile (~/.zshrc, ~/.bashrc) so they are present in
# every Claude Code session. Do NOT commit this file with real values.
#
# See README.md "Secret hygiene" before touching this value.

# Your Caddy bearer token, issued by the one-time exchange URL Tucker
# sends after invite approval. Long-lived; treat like a password.
CADDY_BEARER_TOKEN=caddy_PLACEHOLDER_REPLACE_ME

# Optional: override the Caddy MCP endpoint. Defaults to the production
# Caddy endpoint (api.meetcaddy.com) inside bin/caddy-mcp-proxy.mjs. Leave
# commented out unless Tucker has told you to point at a staging or alternate environment.
# CADDY_MCP_URL=https://api.meetcaddy.com/api/mcp
